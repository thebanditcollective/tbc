---
import '../styles/global.css';
import { withBase } from '../lib/paths';

type Props = {
  title?: string;
  description?: string;
  pathname?: string;
  pageBackgroundImage?: string;
  pageBackgroundColor?: string;
  pageBackgroundPosition?: string;
  pageBackgroundOverlay?: number;
};

const {
  title = 'The Bandit Collective',
  description = 'Editorial interiors portfolio for The Bandit Collective.',
  pathname = '/',
  pageBackgroundImage,
  pageBackgroundColor,
  pageBackgroundPosition = 'center center',
  pageBackgroundOverlay = 0.55
} = Astro.props;

const siteUrl = Astro.site ? new URL(pathname, Astro.site).toString() : undefined;
const isHome = pathname === '/';
const hasPageBackground = Boolean(pageBackgroundImage || pageBackgroundColor);
const desktopNavItems = [
  { href: '/interiors', label: 'Interiors' },
  { href: '/services', label: 'Services' },
  { href: '/shop', label: 'Shop' },
  { href: '/contact', label: 'Contact' }
];
const mobileNavItems = [
  { href: '/interiors', label: 'Interiors' },
  { href: '/services', label: 'Services' },
  { href: '/shop', label: 'Shop' },
  { href: '/contact', label: 'Contact' }
];
const instagramUrl = 'https://www.instagram.com/thebandit.collective';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {siteUrl && <link rel="canonical" href={siteUrl} />}
    <meta name="theme-color" content="#FDFBF7" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@700&family=Manrope:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class:list={['site-body', { 'is-home': isHome, 'has-page-background': hasPageBackground }]}
    style={pageBackgroundColor ? `--page-background-color: ${pageBackgroundColor};` : undefined}
  >
    {pageBackgroundImage && (
      <div
        class="site-page-background"
        aria-hidden="true"
        style={`--page-background-overlay: ${pageBackgroundOverlay}; --page-background-position: ${pageBackgroundPosition};`}
      >
        <img src={pageBackgroundImage} alt="" loading="eager" decoding="sync" />
      </div>
    )}

    <header class:list={['site-header', { 'is-home': isHome, 'has-page-background': hasPageBackground }]} data-site-header>
      <div class="site-header__inner">
        <a class="site-header__brand" href={withBase('/')}>The Bandit Collective</a>
        <nav class="site-header__nav" aria-label="Primary navigation">
          {desktopNavItems.map((item) => {
            const active = pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href));
            return (
              <a class:list={['site-header__link', { 'is-active': active }]} href={withBase(item.href)}>
                {item.label}
              </a>
            );
          })}
        </nav>

        <button
          class="site-header__toggle"
          type="button"
          aria-expanded="false"
          aria-controls="mobile-menu"
          data-menu-toggle
        >
          <span class="sr-only">Open navigation</span>
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>

      <div class="site-header__mobile-panel" id="mobile-menu" data-mobile-menu hidden>
        <nav class="site-header__mobile-nav shell" aria-label="Mobile navigation">
          {mobileNavItems.map((item) => {
            const active = pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href));
            return (
              <a class:list={['site-header__mobile-link', { 'is-active': active }]} href={withBase(item.href)}>
                {item.label}
              </a>
            );
          })}
        </nav>
      </div>
    </header>
    <main class:list={['site-main', { 'site-main--offset': !isHome }]}>
      <slot />
    </main>

    <footer class:list={['site-footer', { 'has-page-background': hasPageBackground }]}>
      <div class="shell site-footer__inner">
        <span>New York, NY</span>
        <span class="site-footer__divider" aria-hidden="true">|</span>
        <a href="mailto:banditcollective.nyc@gmail.com">banditcollective.nyc@gmail.com</a>
        <span class="site-footer__divider" aria-hidden="true">|</span>
        <a class="site-footer__instagram" href={instagramUrl} target="_blank" rel="noreferrer">
          <svg class="site-footer__instagram-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.7" />
            <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.7" />
            <circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" />
          </svg>
          <span class="sr-only">Instagram</span>
        </a>
        <span class="site-footer__divider" aria-hidden="true">|</span>
        <p class="site-footer__copyright">&copy; TBC 2026</p>
      </div>
    </footer>

    <script is:inline>
      const header = document.querySelector('[data-site-header]');
      const toggle = document.querySelector('[data-menu-toggle]');
      const mobileMenu = document.querySelector('[data-mobile-menu]');
      const mobileLinks = mobileMenu ? mobileMenu.querySelectorAll('a') : [];
      let menuCloseTimer;

      const syncHeader = () => {
        if (!header) return;
        const isScrolled = window.scrollY > 1;
        header.classList.toggle('is-scrolled', isScrolled);
        header.style.setProperty('--header-scroll-progress', isScrolled ? '1' : '0');
      };

      const closeMenu = () => {
        if (!toggle || !mobileMenu) return;
        window.clearTimeout(menuCloseTimer);
        toggle.setAttribute('aria-expanded', 'false');
        header?.classList.remove('is-menu-open');
        menuCloseTimer = window.setTimeout(() => {
          mobileMenu.setAttribute('hidden', '');
        }, 260);
      };

      toggle?.addEventListener('click', () => {
        if (!mobileMenu) return;
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', expanded ? 'false' : 'true');
        if (expanded) {
          closeMenu();
        } else {
          window.clearTimeout(menuCloseTimer);
          mobileMenu.removeAttribute('hidden');
          window.requestAnimationFrame(() => {
            header?.classList.add('is-menu-open');
          });
        }
      });

      mobileLinks.forEach((link) => link.addEventListener('click', closeMenu));

      window.addEventListener('scroll', syncHeader, { passive: true });
      window.addEventListener('resize', () => {
        if (window.innerWidth > 860) closeMenu();
      });
      syncHeader();
    </script>
  </body>
</html>

<style>
  .site-header {
    --header-scroll-progress: 0;
    --header-base-red: 220;
    --header-base-green: 203;
    --header-base-blue: 144;
    --header-base-alpha: 1;
    --header-scroll-alpha: 0.3;
    --header-red: calc(var(--header-base-red) * (1 - var(--header-scroll-progress)));
    --header-green: calc(var(--header-base-green) * (1 - var(--header-scroll-progress)));
    --header-blue: calc(var(--header-base-blue) * (1 - var(--header-scroll-progress)));
    --header-alpha: calc(
      var(--header-base-alpha) + (var(--header-scroll-alpha) - var(--header-base-alpha)) * var(--header-scroll-progress)
    );
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 20;
    background-color: rgba(var(--header-red), var(--header-green), var(--header-blue), var(--header-alpha));
    transition:
      background-color 280ms ease,
      backdrop-filter 280ms ease,
      border-color 280ms ease,
      color 280ms ease;
    border-bottom: 1px solid rgba(43, 43, 43, 0.06);
  }

  .site-header.is-home,
  .site-header:not(.is-scrolled):not(.is-menu-open) {
    --header-base-red: 0;
    --header-base-green: 0;
    --header-base-blue: 0;
    --header-base-alpha: 0;
    border-bottom-color: transparent;
  }

  .site-header.is-scrolled,
  .site-header.is-menu-open {
    backdrop-filter: blur(18px);
    border-bottom-color: rgba(43, 43, 43, 0.08);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    min-height: 78px;
    width: min(calc(100% - 2.5rem), 100%);
    margin: 0 auto;
    transition: min-height 320ms var(--ease-luxury);
  }

  .site-header__brand {
    font-family: var(--font-heading);
    font-size: clamp(1.88rem, 2.35vw, 2.34rem);
    line-height: 1;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
    transition: color 280ms ease;
  }

  .site-header__nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 1.25rem;
  }

  .site-header__link {
    position: relative;
    padding: 0.35rem 0;
    border: 0;
    background: transparent;
    color: var(--color-text);
    font-size: 1.17rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 280ms ease;
  }

  .site-header__link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 240ms var(--ease-luxury);
  }

  .site-header__link:hover,
  .site-header__link:focus-visible,
  .site-header__link.is-active {
    color: var(--color-text);
  }

  .site-header__link:hover::after,
  .site-header__link:focus-visible::after,
  .site-header__link.is-active::after {
    transform: scaleX(1);
  }

  .site-header.is-home:not(.is-scrolled):not(.is-menu-open) .site-header__brand,
  .site-header.is-home:not(.is-scrolled):not(.is-menu-open) .site-header__link,
  .site-header.is-scrolled .site-header__brand,
  .site-header.is-scrolled .site-header__link,
  .site-header.is-menu-open .site-header__brand,
  .site-header.is-menu-open .site-header__link {
    color: #fdfbf7;
  }

  .site-header.is-home:not(.is-scrolled):not(.is-menu-open) .site-header__toggle span:not(.sr-only),
  .site-header.is-scrolled .site-header__toggle span:not(.sr-only),
  .site-header.is-menu-open .site-header__toggle span:not(.sr-only) {
    background: #fdfbf7;
  }

  .site-header__toggle,
  .site-header__mobile-panel {
    display: none;
  }

  .site-header.is-scrolled .site-header__inner {
    min-height: 51px;
  }

  .site-header__toggle {
    width: 2.8rem;
    height: 2.8rem;
    padding: 0;
    border: 0;
    background: transparent;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 0.28rem;
  }

  .site-header__toggle span:not(.sr-only) {
    display: block;
    width: 1.2rem;
    height: 1.5px;
    background: var(--color-text);
    transform-origin: center;
    transition:
      background-color 280ms ease,
      opacity 220ms ease,
      transform 260ms var(--ease-luxury);
  }

  :global(.site-body) {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  :global(.site-body.has-page-background) {
    background: var(--page-background-color, #000);
  }

  .site-page-background {
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    opacity: 0;
    animation: pageBackgroundFadeIn 1600ms ease-out 120ms forwards;
    pointer-events: none;
  }

  .site-page-background img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--page-background-position);
  }

  .site-page-background::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, var(--page-background-overlay));
  }

  @keyframes pageBackgroundFadeIn {
    to {
      opacity: 1;
    }
  }

  .site-main {
    position: relative;
    z-index: 1;
    flex: 1 0 auto;
    min-height: 0;
  }

  .site-main--offset {
    padding-top: 78px;
  }

  .site-footer {
    position: relative;
    z-index: 1;
    padding: 1rem 0;
    border-top: 1px solid var(--color-line);
  }

  .site-footer__inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: 0.6rem;
    align-items: center;
    margin: 0 auto;
    color: var(--color-muted);
    font-size: 0.95rem;
    line-height: 1.5;
    text-align: left;
  }

  .site-footer__instagram {
    display: inline-flex;
    align-items: center;
    color: var(--color-text);
    transition: color 220ms ease;
  }

  .site-footer__instagram:hover,
  .site-footer__instagram:focus-visible {
    color: var(--color-accent);
  }

  .site-footer__instagram-icon {
    flex: 0 0 auto;
  }

  .site-footer__divider {
    color: var(--color-muted);
  }

  .site-footer__copyright {
    margin: 0;
  }

  .site-header.has-page-background {
    --header-base-red: 0;
    --header-base-green: 0;
    --header-base-blue: 0;
    --header-base-alpha: 0;
    border-bottom-color: rgba(253, 251, 247, 0.16);
  }

  .site-header.has-page-background .site-header__brand,
  .site-header.has-page-background .site-header__link {
    color: #fdfbf7;
  }

  .site-header.has-page-background .site-header__link:hover,
  .site-header.has-page-background .site-header__link:focus-visible,
  .site-header.has-page-background .site-header__link.is-active {
    color: #fdfbf7;
  }

  .site-header.has-page-background .site-header__link::after {
    background: rgba(253, 251, 247, 0.9);
  }

  .site-header.has-page-background .site-header__toggle span:not(.sr-only) {
    background: #fdfbf7;
  }

  .site-footer.has-page-background {
    border-top-color: rgba(253, 251, 247, 0.22);
  }

  .site-footer.has-page-background .site-footer__inner,
  .site-footer.has-page-background .site-footer__divider,
  .site-footer.has-page-background a,
  .site-footer.has-page-background .site-footer__instagram {
    color: rgba(253, 251, 247, 0.84);
  }

  .site-footer.has-page-background a:hover,
  .site-footer.has-page-background a:focus-visible,
  .site-footer.has-page-background .site-footer__instagram:hover,
  .site-footer.has-page-background .site-footer__instagram:focus-visible {
    color: #fdfbf7;
  }

  @media (max-width: 860px) {
    .site-footer__inner {
      gap: 0.45rem 0.6rem;
    }

    .site-header__inner {
      min-height: 74px;
      width: min(calc(100% - 1.25rem), 100%);
    }

    .site-header.is-scrolled .site-header__inner {
      min-height: 48px;
    }

    .site-header__nav {
      display: none;
    }

    .site-header__toggle {
      display: inline-flex;
    }

    .site-header__mobile-panel {
      display: block;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      padding: 0 0 0.85rem;
      background: rgba(0, 0, 0, 0.75);
      backdrop-filter: blur(18px);
      border-bottom: 1px solid rgba(43, 43, 43, 0.08);
      opacity: 0;
      pointer-events: none;
      transform: translateY(-0.75rem);
      transition:
        opacity 240ms ease,
        transform 260ms var(--ease-luxury);
    }

    .site-header__mobile-panel[hidden] {
      display: none;
    }

    .site-header.is-menu-open .site-header__toggle span:not(.sr-only):nth-child(2) {
      transform: translateY(calc(0.28rem + 1.5px)) rotate(45deg);
    }

    .site-header.is-menu-open .site-header__toggle span:not(.sr-only):nth-child(3) {
      opacity: 0;
      transform: scaleX(0.3);
    }

    .site-header.is-menu-open .site-header__toggle span:not(.sr-only):nth-child(4) {
      transform: translateY(calc(-0.28rem - 1.5px)) rotate(-45deg);
    }

    .site-header.is-menu-open .site-header__mobile-panel {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
    }

    .site-header__mobile-nav {
      display: grid;
      gap: 0.3rem;
      padding-top: 0.3rem;
    }

    .site-header__mobile-link {
      display: block;
      width: 100%;
      padding: 0.85rem 0;
      border: 0;
      border-bottom: 1px solid rgba(43, 43, 43, 0.08);
      background: transparent;
      color: #fdfbf7;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      font-size: 1rem;
      text-align: left;
    }

    .site-header__mobile-link.is-active {
      color: var(--color-accent);
    }
  }

  @media (max-width: 560px) {
    .site-footer__inner {
      flex-wrap: nowrap;
      max-width: none;
      gap: 0.35rem;
      font-size: 0.58rem;
      white-space: nowrap;
    }

    .site-footer__divider {
      display: none;
    }

    .site-footer__inner > * {
      flex: 0 0 auto;
      white-space: nowrap;
    }

    .site-footer__instagram,
    .site-footer__copyright {
      justify-content: flex-start;
    }

    .site-header__brand {
      max-width: none;
      font-size: 1.45rem;
    }
  }

  @media (min-width: 861px) {
    .site-header__brand {
      font-size: clamp(1.41rem, 1.76vw, 1.76rem);
    }

    .site-header__link {
      font-size: 0.88rem;
    }
  }
</style>
