---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeContact from '../components/HomeContact.astro';
import HomeLookbook from '../components/HomeLookbook.astro';
import HomePressStrip from '../components/HomePressStrip.astro';
import HomeSpectrumFeature from '../components/HomeSpectrumFeature.astro';
import HomeStatement from '../components/HomeStatement.astro';
import { Image } from 'astro:assets';
import heroDesktop01 from '../assets/images/home/hero/hero-desktop-01.jpg';
import heroDesktop02 from '../assets/images/home/hero/hero-desktop-02.jpg';
import heroDesktop03 from '../assets/images/home/hero/hero-desktop-03.jpg';
import heroDesktop04 from '../assets/images/home/hero/hero-desktop-04.jpg';
import heroMobile01 from '../assets/images/home/hero/hero-mobile-01.jpg';
import heroMobile02 from '../assets/images/home/hero/hero-mobile-02.jpg';
import heroMobile03 from '../assets/images/home/hero/hero-mobile-03.jpg';
import heroMobile04 from '../assets/images/home/hero/hero-mobile-04.jpg';

const desktopHeroImages = [
  heroDesktop01,
  heroDesktop02,
  heroDesktop03,
  heroDesktop04
];

const mobileHeroImages = [
  heroMobile01,
  heroMobile02,
  heroMobile03,
  heroMobile04
];
---

<BaseLayout
  title="The Bandit Collective | Interior Design Studio"
  description="Editorial interior design portfolio and studio site for The Bandit Collective."
  pathname="/"
>
  <section class="hero" data-home-hero>
    <div class="hero__stack hero__stack--desktop" aria-hidden="true">
      {desktopHeroImages.map((image, index) => (
        <Image
          class={`hero__image${index === 0 ? ' is-active' : ''}`}
          src={image}
          alt=""
          format="webp"
          quality={82}
          loading={index === 0 ? 'eager' : 'lazy'}
          fetchpriority={index === 0 ? 'high' : 'low'}
          decoding={index === 0 ? 'sync' : 'async'}
          data-home-hero-slide
        />
      ))}
    </div>
    <div class="hero__stack hero__stack--mobile" aria-hidden="true">
      {mobileHeroImages.map((image, index) => (
        <Image
          class={`hero__image${index === 0 ? ' is-active' : ''}`}
          src={image}
          alt=""
          format="webp"
          quality={82}
          loading={index === 0 ? 'eager' : 'lazy'}
          fetchpriority={index === 0 ? 'high' : 'low'}
          decoding={index === 0 ? 'sync' : 'async'}
          data-home-hero-mobile-slide
        />
      ))}
    </div>
    <div class="bc-hero-arrow">
      <a href="#statement" aria-label="Scroll to statement">
        <svg width="20" height="32" viewBox="0 0 20 32" fill="none">
          <path d="M10 6L10 26M10 26L4 20M10 26L16 20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
        </svg>
      </a>
    </div>
  </section>

  <div class="home-flow">
    <HomeStatement />
    <HomeLookbook />
    <HomeSpectrumFeature />
    <HomeContact />
    <HomePressStrip />
  </div>
</BaseLayout>

<script is:inline>
  const homeHero = document.querySelector('[data-home-hero]');

  if (homeHero) {
    const desktopSlides = Array.from(homeHero.querySelectorAll('[data-home-hero-slide]'));
    const mobileSlides = Array.from(homeHero.querySelectorAll('[data-home-hero-mobile-slide]'));
    const mobileQuery = window.matchMedia('(max-width: 720px)');
    let activeIndex = 0;
    let intervalId;

    const getSlides = () => (mobileQuery.matches ? mobileSlides : desktopSlides);

    const showHeroSlide = (index) => {
      const slides = getSlides();
      if (!slides.length) return;
      activeIndex = index % slides.length;
      desktopSlides.forEach((slide, slideIndex) => {
        slide.classList.toggle('is-active', !mobileQuery.matches && slideIndex === activeIndex);
      });
      mobileSlides.forEach((slide, slideIndex) => {
        slide.classList.toggle('is-active', mobileQuery.matches && slideIndex === activeIndex);
      });
    };

    const startHeroRotation = () => {
      window.clearInterval(intervalId);
      intervalId = window.setInterval(() => {
        showHeroSlide(activeIndex + 1);
      }, 5000);
    };

    const pauseHeroRotation = () => window.clearInterval(intervalId);

    homeHero.addEventListener('mouseenter', pauseHeroRotation);
    homeHero.addEventListener('mouseleave', startHeroRotation);
    mobileQuery.addEventListener('change', () => {
      activeIndex = 0;
      showHeroSlide(0);
      startHeroRotation();
    });

    showHeroSlide(0);
    startHeroRotation();
  }
</script>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    overflow: clip;
    background: #e9dfd5;
    opacity: 0;
    animation: heroFadeIn 1600ms ease-out 120ms forwards;
  }

  .hero__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100svh;
    min-height: 100svh;
    object-fit: cover;
    opacity: 0;
    transition: opacity 1600ms ease-in-out;
  }

  .hero__image.is-active {
    opacity: 1;
  }

  .hero__stack {
    display: block;
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero__stack--mobile {
    display: none;
  }

  @keyframes heroFadeIn {
    to {
      opacity: 1;
    }
  }

  .bc-hero-arrow {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .bc-hero-arrow a {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    color: #fdfbf7;
    opacity: 0.8;
    transition: opacity 0.2s ease;
    pointer-events: auto;
  }

  .bc-hero-arrow a:hover {
    opacity: 1;
  }

  .bc-hero-arrow svg {
    animation: bcBounce 2.5s ease-in-out infinite;
    filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.3));
  }

  @keyframes bcBounce {
    0%, 100% {
      transform: translateY(0);
      opacity: 0.75;
    }

    50% {
      transform: translateY(8px);
      opacity: 1;
    }
  }

  .home-flow {
    display: grid;
    gap: var(--section-gap);
    padding: clamp(4rem, 8vw, 7rem) 0 clamp(5rem, 9vw, 8rem);
  }

  @media (max-width: 720px) {
    .hero {
      left: 50%;
      width: 100vw;
      height: 100svh;
      min-height: 100svh;
      max-height: none;
      transform: translateX(-50%);
    }

    .hero__image {
      width: 100vw;
      max-width: none;
      height: 100svh;
      min-height: 100svh;
      max-height: none;
    }

    .hero__stack--desktop {
      display: none;
    }

    .hero__stack--mobile {
      display: block;
    }

    .home-flow {
      gap: 2.5rem;
      padding: 1.5rem 0 4rem;
    }
  }
</style>
