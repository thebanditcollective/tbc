---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import servicesImage from '../assets/images/services/services-01.jpg';

const serviceGroups = [
  {
    title: 'Interior Design & Decorating',
    tagline:
      'A considered approach to spaces that need a complete point of view, from the initial design to the final layer.',
    items: ['Residential Design', 'Commercial Design']
  },
  {
    title: 'Consultations',
    tagline: 'Focused guidance for the details that shape how a space comes together.',
    items: ['Color', 'Lighting']
  }
];
---

<BaseLayout
  title="Services | Bandit Collective"
  description="Interior design, decorating, and consultation services by The Bandit Collective."
  pathname="/services"
>
  <section class="services-page" aria-label="Services">
    <div class="services-page__image">
      <Image
        src={servicesImage}
        alt="Layered interior room with warm furnishings and collected details"
        format="webp"
        quality={84}
        loading="eager"
        fetchpriority="high"
        decoding="sync"
      />
    </div>

    <div class="services-page__content">
      {serviceGroups.map((service) => (
        <article class="services-page__group">
          <h1>{service.title}</h1>
          <p>{service.tagline}</p>
          <ul>
            {service.items.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  :global(.site-main:has(.services-page)) {
    min-height: auto;
  }

  .services-page {
    --services-footer-space: 91px;
    display: grid;
    grid-template-columns: minmax(0, 0.72fr) minmax(18rem, 0.88fr);
    gap: clamp(1.25rem, 3vw, 3.5rem);
    align-items: center;
    width: min(calc(100% - (var(--page-pad) * 2)), var(--max-shell));
    height: calc(100svh - 78px - var(--services-footer-space));
    min-height: 34rem;
    margin: 0 auto;
    padding: clamp(1.25rem, 3vw, 2.25rem) 0;
    opacity: 0;
    transform: translateY(16px);
    animation: servicesPageIn 1400ms var(--ease-luxury) 120ms forwards;
  }

  .services-page__image {
    display: flex;
    justify-content: center;
    align-items: center;
    width: auto;
    max-width: 100%;
    height: 100%;
    aspect-ratio: 3712 / 5568;
    justify-self: end;
    min-height: 0;
    overflow: hidden;
  }

  .services-page__image img {
    width: 100%;
    height: 100%;
    max-width: 100%;
    object-fit: contain;
  }

  .services-page__content {
    display: grid;
    gap: clamp(2rem, 6vh, 4.25rem);
    align-content: center;
    max-width: 32rem;
  }

  .services-page__group {
    display: grid;
    gap: clamp(0.4rem, 0.75vh, 0.575rem);
  }

  .services-page__group h1 {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 2.55vw, 3rem);
    font-weight: 700;
    line-height: 0.98;
  }

  .services-page__group p {
    max-width: 28rem;
    margin: 0;
    color: var(--color-muted);
    font-family: var(--font-heading);
    font-size: clamp(0.8625rem, 1.2375vw, 1.275rem);
    line-height: 1.34;
  }

  .services-page__group ul {
    display: grid;
    gap: 0.225rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .services-page__group li {
    color: var(--color-text);
    font-size: clamp(0.615rem, 0.7125vw, 0.7125rem);
    font-weight: 700;
    letter-spacing: 0.12em;
    line-height: 1.5;
    text-transform: uppercase;
  }

  @keyframes servicesPageIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 900px) {
    :global(.site-main:has(.services-page)) {
      min-height: 100vh;
    }

    .services-page {
      grid-template-columns: 1fr;
      gap: 2.25rem;
      height: auto;
      min-height: 0;
      padding: 2rem 0 4.5rem;
    }

    .services-page__image {
      height: auto;
      aspect-ratio: 4 / 5;
    }

    .services-page__content {
      max-width: none;
      gap: 2.75rem;
    }
  }

  @media (max-width: 720px) {
    :global(.site-body:has(.services-page) .site-footer) {
      padding: 0.6rem 0;
    }

    :global(.site-body:has(.services-page) .site-footer__inner) {
      flex-wrap: nowrap;
      max-width: none;
      gap: 0.35rem;
      font-size: 0.58rem;
      white-space: nowrap;
    }

    :global(.site-body:has(.services-page) .site-footer__divider) {
      display: none;
    }

    :global(.site-body:has(.services-page) .site-footer__inner > *) {
      flex: 0 0 auto;
      white-space: nowrap;
    }

    .services-page {
      width: min(calc(100% - (var(--page-pad) * 2)), var(--max-shell));
      height: calc(100svh - 74px - 43px);
      min-height: 0;
      padding: 0.75rem 0 0.5rem;
      gap: 0;
      align-items: stretch;
    }

    .services-page__image {
      display: none;
    }

    .services-page__content {
      width: 100%;
      height: 100%;
      margin: 0;
      gap: clamp(1.1rem, 2.5vh, 1.6rem);
      align-content: center;
    }

    .services-page__group {
      gap: 0.55rem;
    }

    .services-page__group h1 {
      font-size: clamp(1.85rem, 6.1vw, 2.35rem);
    }

    .services-page__group p {
      max-width: none;
      font-size: clamp(1rem, 3.25vw, 1.12rem);
      line-height: 1.28;
    }

    .services-page__group ul {
      gap: 0.32rem;
    }

    .services-page__group li {
      font-size: clamp(0.78rem, 2.75vw, 0.88rem);
      line-height: 1.35;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .services-page {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>
