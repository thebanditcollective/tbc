---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectTile from '../../components/ProjectTile.astro';
import { getProjects } from '../../lib/content';
import { withBase } from '../../lib/paths';

const projects = await getProjects();
---

<BaseLayout
  title="Interiors | Bandit Collective"
  description="Portfolio of interior design work by Bandit Collective."
  pathname="/interiors"
>
  <section class="interiors shell">
    <div class="interiors__grid">
      {projects.map((project) => (
        <ProjectTile
          href={withBase(`/interiors/${project.slug}`)}
          title={project.data.title}
          images={project.data.coverImages.map((image) => ({
            src: image.src,
            alt: `${project.data.title} cover image`
          }))}
        />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  :global(.site-main--offset) {
    display: flex;
  }

  .interiors {
    flex: 1;
    display: grid;
    align-items: center;
    padding-top: 0;
    padding-bottom: 0;
    animation: interiors-page-enter 1.35s var(--ease-luxury) both;
  }

  .interiors__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: 56px;
    row-gap: 80px;
  }

  @media (max-width: 900px) {
    .interiors__grid {
      grid-template-columns: 1fr;
      row-gap: 64px;
    }
  }

  @media (max-width: 720px) {
    .interiors {
      padding-top: 24px;
      padding-bottom: 24px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .interiors {
      animation: none;
    }
  }

  @keyframes interiors-page-enter {
    from {
      opacity: 0;
      transform: translateY(28px);
      filter: blur(8px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }
</style>
