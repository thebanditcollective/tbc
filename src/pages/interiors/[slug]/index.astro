---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getProjects, getProjectBySlug } from '../../../lib/content';
import { withBase } from '../../../lib/paths';

export async function getStaticPaths() {
  const projects = await getProjects();
  return projects.map((project) => ({
    params: { slug: project.slug }
  }));
}

const { slug } = Astro.params;
const project = slug ? await getProjectBySlug(slug) : undefined;

if (!project) {
  throw new Error(`Project not found for slug: ${slug}`);
}

const projects = await getProjects();
const nextProject = projects.find((item) => item.slug === project.data.nextProjectSlug) ?? projects[0];
const meta = [project.data.location, project.data.year].filter(Boolean).join(' / ');
---

<BaseLayout
  title={`${project.data.title} | Bandit Collective`}
  description={project.data.shortDescription}
  pathname={`/interiors/${project.slug}`}
>
  <article class="case-study">
    <section class="case-study__header shell">
      <a class="case-study__back" href={withBase('/interiors')}>Back to Interiors</a>
      <h1>{project.data.title}</h1>
      {meta && <p class="case-study__meta">{meta}</p>}
      <p class="case-study__description">{project.data.shortDescription}</p>
    </section>

    <section class="case-study__story">
      {project.data.storyImages.map((image, index) => (
        <figure class="case-study__story-item">
          <Image
            src={image}
            alt={`${project.data.title} story image ${index + 1}`}
            loading={index === 0 ? 'eager' : 'lazy'}
            quality={80}
          />
        </figure>
      ))}

      {project.data.diptychs?.map((diptych, index) => (
        <figure class="case-study__diptych">
          <Image
            src={diptych.left}
            alt={`${project.data.title} diptych ${index + 1}, left image`}
            loading="lazy"
            quality={80}
          />
          <Image
            src={diptych.right}
            alt={`${project.data.title} diptych ${index + 1}, right image`}
            loading="lazy"
            quality={80}
          />
        </figure>
      ))}
    </section>

    <footer class="case-study__next shell">
      <a href={withBase(`/interiors/${nextProject.slug}`)}>
        <span>Next Project</span>
        <strong>{nextProject.data.title}</strong>
      </a>
    </footer>
  </article>
</BaseLayout>

<style>
  .case-study {
    padding-top: 96px;
    padding-bottom: 96px;
  }

  .case-study__header {
    display: grid;
    gap: 0.8rem;
    padding-top: 4rem;
    padding-bottom: 5rem;
  }

  .case-study__back {
    color: var(--color-accent);
    font-size: 0.92rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .case-study__header h1 {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(3rem, 6vw, 5.6rem);
    line-height: 0.95;
  }

  .case-study__meta {
    margin: 0;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.92rem;
  }

  .case-study__description {
    max-width: 50ch;
    margin: 0;
    color: var(--color-muted);
    line-height: 1.8;
  }

  .case-study__story {
    display: grid;
    gap: 72px;
  }

  .case-study__story-item {
    width: min(1120px, calc(100% - 16vw));
    margin: 0 auto;
  }

  .case-study__story-item img,
  .case-study__diptych img {
    display: block;
    width: 100%;
    height: auto;
  }

  .case-study__diptych {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 32px;
    width: min(1120px, calc(100% - 16vw));
    margin: 0 auto;
  }

  .case-study__next {
    display: flex;
    justify-content: flex-end;
    padding-top: 5rem;
  }

  .case-study__next a {
    display: grid;
    gap: 0.35rem;
    text-align: right;
  }

  .case-study__next span {
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.86rem;
  }

  .case-study__next strong {
    font-size: 0.86rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @media (min-width: 721px) {
    .case-study__story-item {
      display: grid;
      justify-items: center;
    }

    .case-study__story-item img,
    .case-study__diptych img {
      width: auto;
      max-width: 100%;
      max-height: calc(100svh - 120px);
    }

    .case-study__diptych {
      align-items: center;
    }

    .case-study__diptych img {
      justify-self: center;
    }
  }

  @media (max-width: 720px) {
    .case-study {
      padding-top: 72px;
    }

    .case-study__header {
      text-align: center;
    }

    .case-study__story {
      gap: 48px;
    }

    .case-study__story-item,
    .case-study__diptych {
      width: calc(100% - (var(--page-pad) * 2));
    }

    .case-study__diptych {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .case-study__next {
      justify-content: center;
    }

    .case-study__next a {
      text-align: center;
    }
  }
</style>
