---
import { withBase } from '../lib/paths';
---

<section class="home-spectrum">
  <div class="home-spectrum__image">
    <img
      src={withBase('/images/home/home-hero-2.jpg')}
      alt="Interior detail showing layered materials and color"
      width="1600"
      height="900"
    />
  </div>
  <div class="home-spectrum__line">
    <div class="home-spectrum__text shell">
      <span class="home-spectrum__left">From the first color</span>
      <span class="home-spectrum__arrow" aria-hidden="true">
        <svg width="100%" height="2" viewBox="0 0 200 2" preserveAspectRatio="none">
          <line x1="0" y1="1" x2="195" y2="1" stroke="currentColor" stroke-width="1" />
          <path d="M195 1L200 1L195 1" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>
      <span class="home-spectrum__right">to the final detail</span>
    </div>
  </div>
</section>

<style>
  .home-spectrum {
    background: var(--color-bg);
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    width: 100%;
    min-height: 100svh;
    position: relative;
    overflow: hidden;
  }

  .home-spectrum__image {
    width: 100%;
    height: 100%;
    min-height: 0;
    overflow: hidden;
  }

  .home-spectrum__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    display: block;
  }

  .home-spectrum__line {
    padding: clamp(3.5rem, 7vh, 4.5rem) 0 clamp(4rem, 8vh, 5.5rem);
    background: var(--color-bg);
  }

  .home-spectrum__text {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
  }

  .home-spectrum__left,
  .home-spectrum__right {
    flex-shrink: 0;
    color: var(--color-text);
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3.5vw, 2.375rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }

  .home-spectrum__arrow {
    flex: 1 1 auto;
    min-width: 5rem;
    max-width: 15rem;
    height: 2px;
    color: var(--color-accent);
    opacity: 0.7;
    animation: homeSpectrumDraw 1.2s var(--ease-luxury) 300ms both;
  }

  .home-spectrum__arrow svg {
    display: block;
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  @keyframes homeSpectrumDraw {
    from {
      clip-path: inset(0 100% 0 0);
      opacity: 0;
    }

    to {
      clip-path: inset(0 0 0 0);
      opacity: 0.7;
    }
  }

  @media (max-width: 767px) {
    .home-spectrum__image {
      min-height: 55svh;
    }

    .home-spectrum__image img {
      object-position: 50% 55%;
    }

    .home-spectrum__line {
      padding: 3.5rem 0 4rem;
    }

    .home-spectrum__text {
      flex-wrap: wrap;
      gap: 1rem;
    }

    .home-spectrum__left,
    .home-spectrum__right {
      flex-basis: 100%;
      text-align: center;
      white-space: normal;
    }

    .home-spectrum__arrow {
      order: 2;
      max-width: 10rem;
      margin: 0.5rem 0;
    }
  }
</style>
