---
type Slide = {
  src: string;
  alt: string;
  title?: string;
};

type Props = {
  slides: Slide[];
};

const { slides } = Astro.props;
---

<section class="featured shell">
  <div class="featured__header">
    <p class="eyebrow">Featured Rooms</p>
    <h2 class="section-title">A first look into the collection.</h2>
  </div>

  <div class="featured__viewport" data-carousel>
    <div class="featured__track" data-carousel-track tabindex="0" aria-label="Featured interiors gallery">
      {slides.map((slide, index) => (
        <article class="featured__card" data-carousel-slide>
          <img
            src={slide.src}
            alt={slide.alt}
            loading={index < 2 ? 'eager' : 'lazy'}
            width="1200"
            height="900"
          />
          {slide.title && <p>{slide.title}</p>}
        </article>
      ))}
    </div>
    <div class="featured__dots" aria-hidden="true">
      {slides.map((_, index) => (
        <button
          class:list={['featured__dot', { 'is-active': index === 0 }]}
          type="button"
          data-carousel-dot
        >
          <span class="sr-only">Go to slide {index + 1}</span>
        </button>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  const carousels = document.querySelectorAll('[data-carousel]');

  carousels.forEach((carousel) => {
    const track = carousel.querySelector('[data-carousel-track]');
    const slides = Array.from(carousel.querySelectorAll('[data-carousel-slide]'));
    const dots = Array.from(carousel.querySelectorAll('[data-carousel-dot]'));
    if (!track || !slides.length || !dots.length) return;

    const update = () => {
      const trackRect = track.getBoundingClientRect();
      let activeIndex = 0;
      let closestDistance = Number.POSITIVE_INFINITY;

      slides.forEach((slide, index) => {
        const rect = slide.getBoundingClientRect();
        const distance = Math.abs(rect.left - trackRect.left);
        if (distance < closestDistance) {
          closestDistance = distance;
          activeIndex = index;
        }
      });

      dots.forEach((dot, index) => {
        dot.classList.toggle('is-active', index === activeIndex);
      });
    };

    track.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        slides[index]?.scrollIntoView({ behavior: 'smooth', inline: 'start', block: 'nearest' });
      });
    });

    update();
  });
</script>

<style>
  .featured {
    display: grid;
    gap: 2rem;
  }

  .featured__header {
    display: grid;
    gap: 1rem;
    max-width: 46rem;
  }

  .featured__viewport {
    display: grid;
    gap: 1.2rem;
  }

  .featured__track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(15rem, 19rem);
    gap: 0.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    padding: 0.25rem 0 0.25rem;
  }

  .featured__track::-webkit-scrollbar {
    display: none;
  }

  .featured__card {
    scroll-snap-align: start;
    display: grid;
    gap: 0.85rem;
  }

  .featured__card img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    background: var(--color-surface);
    border: 4px solid #ffffff;
    max-height: 24rem;
  }

  .featured__card p {
    margin: 0;
    color: var(--color-muted);
  }

  .featured__dots {
    display: flex;
    gap: 0.65rem;
    justify-content: center;
  }

  .featured__dot {
    width: 0.6rem;
    height: 0.6rem;
    padding: 0;
    border: 0;
    border-radius: 999px;
    background: rgba(43, 43, 43, 0.18);
    transition: transform 200ms var(--ease-luxury), background-color 200ms ease;
  }

  .featured__dot.is-active {
    transform: scale(1.25);
    background: var(--color-accent);
  }

  @media (max-width: 720px) {
    .featured {
      gap: 1.4rem;
    }

    .featured__header {
      gap: 0.75rem;
    }

    .featured__track {
      grid-auto-columns: 78%;
      padding-right: 14%;
    }

    .featured__card p {
      display: none;
    }

    .featured__card img {
      max-height: min(56vh, 26rem);
    }
  }
</style>
