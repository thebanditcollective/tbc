<section class="home-statement" id="statement" data-home-statement>
  <div class="home-statement__inner shell">
    <h2 class="home-statement__title" data-home-statement-item>
      <span>Curating spaces that</span><br />
      <span>tell <em>your</em> story</span>
    </h2>
  </div>
</section>

<script is:inline>
  const statementSection = document.querySelector('[data-home-statement]');
  const statementItems = statementSection?.querySelectorAll('[data-home-statement-item]') ?? [];

  if (statementItems.length) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        });
      },
      { threshold: 0.35 }
    );

    statementItems.forEach((item) => observer.observe(item));
  }
</script>

<style>
  .home-statement {
    background: var(--color-bg);
    overflow: hidden;
  }

  .home-statement__inner {
    display: grid;
    justify-items: center;
    align-content: center;
    min-height: auto;
    padding-top: clamp(2rem, 4vw, 3rem);
    padding-bottom: clamp(2rem, 4vw, 3rem);
    text-align: center;
  }

  .home-statement__title {
    opacity: 0;
    transform: scale(0.92) translateY(20px);
    transition:
      opacity 900ms var(--ease-luxury),
      transform 900ms var(--ease-luxury);
    will-change: opacity, transform;
  }

  .home-statement__title {
    max-width: 18ch;
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(3.6rem, 4.65vw, 5.05rem);
    font-weight: 700;
    line-height: 1.16;
    letter-spacing: 0.07em;
    color: var(--color-text);
  }

  .home-statement__title em {
    font-style: italic;
    font-weight: 400;
  }

  .home-statement__title span {
    white-space: nowrap;
  }

  .home-statement__title.is-visible {
    opacity: 1;
    transform: scale(1) translateY(0);
  }

  @media (max-width: 767px) {
    .home-statement__inner {
      min-height: auto;
      padding-top: 1rem;
      padding-bottom: 1rem;
    }

    .home-statement__title {
      max-width: 18ch;
      font-size: clamp(2.7rem, 12vw, 4rem);
      letter-spacing: 0.04em;
    }

    .home-statement__title span {
      white-space: normal;
    }

  }
</style>
