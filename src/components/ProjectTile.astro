---
import CrossfadeStack from './CrossfadeStack.astro';

type TileImage = {
  src: string;
  alt: string;
};

type Props = {
  href: string;
  title: string;
  images: TileImage[];
};

const { href, title, images } = Astro.props;
---

<a class="project-tile" href={href}>
  <div class="project-tile__media">
    <CrossfadeStack images={images} interval={4000} />
    <h2 class="project-tile__title">{title}</h2>
  </div>
</a>

<style>
  .project-tile {
    display: block;
  }

  .project-tile:hover .project-tile__media :global(.crossfade-stack__image.is-active),
  .project-tile:focus-visible .project-tile__media :global(.crossfade-stack__image.is-active) {
    transform: scale(1.03);
  }

  .project-tile__media {
    position: relative;
    width: 85%;
    margin: 0 auto;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--color-surface);
  }

  .project-tile__media::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: rgba(0, 0, 0, 0.42);
    opacity: 0;
    transition: opacity 280ms ease;
  }

  .project-tile:hover .project-tile__media::after,
  .project-tile:focus-visible .project-tile__media::after {
    opacity: 1;
  }

  .project-tile__title {
    position: absolute;
    left: 50%;
    top: 50%;
    z-index: 2;
    margin: 0;
    padding: 0.65rem 1rem;
    color: #fff;
    font-family: var(--font-heading);
    font-size: clamp(1.9rem, 4vw, 2.5rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.08em;
    text-align: center;
    text-transform: uppercase;
    transform: translate(-50%, -50%);
    white-space: nowrap;
  }

  @media (max-width: 720px) {
    .project-tile__title {
      width: min(calc(100% - 2rem), 22rem);
      white-space: normal;
    }
  }
</style>
